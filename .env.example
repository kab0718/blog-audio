# Google Cloud Text-to-Speech target settings.
# Local development uses Application Default Credentials:
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project YOUR_PROJECT_ID
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_TTS_LANGUAGE_CODE=ja-JP
GOOGLE_CLOUD_TTS_VOICE=ja-JP-Neural2-B
GOOGLE_CLOUD_TTS_AUDIO_ENCODING=MP3

# Optional local service account key path. Do not commit key files.
GOOGLE_APPLICATION_CREDENTIALS=

# Current legacy TTS adapter uses OpenAI until the Google Cloud adapter is implemented.
OPENAI_API_KEY=

# Optional: set to local-preview to use the generated preview tone instead of /api/tts.
VITE_TTS_PROVIDER=
